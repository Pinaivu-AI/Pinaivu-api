# Copy to .env.local

# API Gateway (auth, keys, usage)
GATEWAY_URL=http://localhost:4001

# Coordinator enclave (health, models — direct)
COORDINATOR_URL=https://localhost:4000

# Admin secret — must match ADMIN_SECRET in gateway/.env
ADMIN_SECRET=local-dev-secret

# Your operator account UUID (get from /setup page)
DASHBOARD_ACCOUNT_ID=

# An active API key for reading usage stats
DASHBOARD_API_KEY=sk-pnv-
