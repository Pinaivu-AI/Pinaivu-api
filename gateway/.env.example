# Shared with the coordinator — same Postgres and Redis instance
DATABASE_URL=postgres://pinaivu:pinaivu@localhost:5432/pinaivu
REDIS_URL=redis://localhost:6379

# URL of the coordinator (coordinator's HTTPS endpoint)
COORDINATOR_URL=https://localhost:4000

# Admin secret — used by the dashboard to manage accounts/keys
# Must also be set in the dashboard's .env.local as ADMIN_SECRET
ADMIN_SECRET=local-dev-secret

# Gateway port (clients call this, NOT the coordinator directly)
PORT=4001
